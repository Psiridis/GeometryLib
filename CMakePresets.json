{
  "version": 4,
  "vendor": {
    "geometry": {}
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "Default build using native generators",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "hidden": true
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "description": "Debug build with symbols",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "description": "Release build with optimizations",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer",
      "generator": "Ninja",
      "description": "Debug build with AddressSanitizer",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build-asan",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address",
        "BUILD_TESTING": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Debug",
      "jobs": 0
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Release",
      "jobs": 0
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "displayName": "AddressSanitizer",
      "jobs": 0
    },
    {
      "name": "install-debug",
      "configurePreset": "debug",
      "targets": [
        "install"
      ]
    },
    {
      "name": "install-release",
      "configurePreset": "release",
      "targets": [
        "install"
      ]
    },
    {
      "name": "install-asan",
      "configurePreset": "asan",
      "targets": [
        "install"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Debug Tests",
      "inherits": "default"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Release Tests",
      "inherits": "default"
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "displayName": "AddressSanitizer Tests",
      "inherits": "default"
    }
  ]
}